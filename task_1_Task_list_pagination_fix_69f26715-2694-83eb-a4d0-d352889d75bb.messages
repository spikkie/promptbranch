ath: Path) -> None:\\n (tmp_path / \"VERSION\").write_text(\"v0.0.test\\\\n\", encoding=\"utf-8\")\\n payload = mcp_host_smoke(\\n repo_path=tmp_path,\\n profile_dir=tmp_path / \".pb_profile\",\\n command=__import__(\"sys\").executable,\\n resolve_command=False,\\n timeout_seconds=10.0,\\n )\\n\\n # sys.executable alone is not a Promptbranch executable; this should be a\\n # deterministic launch failure rather than a silent false positive.\\n assert payload[\"ok\"] is False\\n assert payload[\"action\"] == \"mcp_host_smoke\"\\n''') p.write_text(s) PY",
