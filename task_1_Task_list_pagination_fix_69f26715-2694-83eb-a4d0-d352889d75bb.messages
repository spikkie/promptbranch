ion=\"store_true\", help=\"Include gated write/process tools in addition to read-only tools.\")\\n mcp_manifest.add_argument(\"--json\", action=\"store_true\")\\n\\n''' if needle not in s: raise SystemExit('parser needle not found') s=s.replace(needle, insert+needle, 1) p.write_text(s) PY grep -n \"agent =\\|mcp =\" promptbranch_cli.py",
