      "text": "Going back to ollama_mcp_verification_harness_v2 Wy does it take so long or is this command hanging? ± |main ?:4 ✗| → python3 verify_ollama_mcp_trust_v2.py --repo-path /home/spikkie/git/chatgpt_claudecode_workflow --models qwen2.5-coder:3b --try-langchain --execute-first-valid ^CTraceback (most recent call last): File \"/home/spikkie/git/chatgpt_claudecode_workflow/ollama_mcp_verification_harness_v2/verify_ollama_mcp_trust_v2.py\", line 232, in <module> raise SystemExit(main()) ^^^^^^ File \"/home/spikkie/git/chatgpt_claudecode_workflow/ollama_mcp_verification_harness_v2/verify_ollama_mcp_trust_v2.py\", line 217, in main proposals.append(langchain_chatollama_tools(model, args.prompt, args.timeout)) ^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^ File \"/home/spikkie/git/chatgpt_claudecode_workflow/ollama_mcp_verification_harness_v2/verify_ollama_mcp_trust_v2.py\", line 167, in langchain_chatollama_tools result = ChatOllama(model=model, temperature=0).bind_tools([read_file, git_status, git_diff_summary]).invoke(user_request) ^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^ File \"/home/spikkie/git/ai-aip/py_env/lib/python3.12/site-packages/langchain_core/runnables/base.py\", line 5720, in invoke return self.bound.invoke( ^^^^^^^^^^^^^^^^^^ File \"/home/spikkie/git/ai-aip/py_env/lib/python3.12/site-packages/langchain_core/language_models/chat_models.py\", line 395, in invoke self.generate_prompt( File \"/home/spikkie/git/ai-aip/py_env/lib/python3.12/site-packages/langchain_core/language_models/chat_models.py\", line 1025, in generate_prompt return self.generate(prompt_messages, stop=stop, callbacks=callbacks, **kwargs) ^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^ File \"/home/spikkie/git/ai-aip/py_env/lib/python3.12/site-packages/langchain_core/language_models/chat_models.py\", line 842, in generate self._generate_with_cache( File \"/home/spikkie/git/ai-aip/py_env/lib/python3.12/site-packages/langchain_core/language_models/chat_models.py\", line 1091, in _generate_with_cache result = self._generate( ^^^^^^^^^^^^^^^ File \"/home/spikkie/git/ai-aip/py_env/lib/python3.12/site-packages/langchain_ollama/chat_models.py\", line 741, in _generate final_chunk = self._chat_stream_with_aggregation( ^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^ File \"/home/spikkie/git/ai-aip/py_env/lib/python3.12/site-packages/langchain_ollama/chat_models.py\", line 678, in _chat_stream_with_aggregation for chunk in self._iterate_over_stream(messages, stop, **kwargs): File \"/home/spikkie/git/ai-aip/py_env/lib/python3.12/site-packages/langchain_ollama/chat_models.py\", line 763, in _iterate_over_stream for stream_resp in self._create_chat_stream(messages, stop, **kwargs): File \"/home/spikkie/git/ai-aip/py_env/lib/python3.12/site-packages/langchain_ollama/chat_models.py\", line 665, in _create_chat_stream yield from self._client.chat(**chat_params) File \"/home/spikkie/git/ai-aip/py_env/lib/python3.12/site-packages/ollama/_client.py\", line 181, in inner for line in r.iter_lines(): File \"/home/spikkie/git/ai-aip/py_env/lib/python3.12/site-packages/httpx/_models.py\", line 929, in iter_lines for text in self.iter_text(): File \"/home/spikkie/git/ai-aip/py_env/lib/python3.12/site-packages/httpx/_models.py\", line 916, in iter_text for byte_content in self.iter_bytes(): File \"/home/spikkie/git/ai-aip/py_env/lib/python3.12/site-packages/httpx/_models.py\", line 897, in iter_bytes for raw_bytes in self.iter_raw(): File \"/home/spikkie/git/ai-aip/py_env/lib/python3.12/site-packages/httpx/_models.py\", line 951, in iter_raw for raw_stream_bytes in self.stream: File \"/home/spikkie/git/ai-aip/py_env/lib/python3.12/site-packages/httpx/_client.py\", line 153, in __iter__ for chunk in self._stream: File \"/home/spikkie/git/ai-aip/py_env/lib/python3.12/site-packages/httpx/_transports/default.py\", line 127, in __iter__ for part in self._httpcore_stream: File \"/home/spikkie/git/ai-aip/py_env/lib/python3.12/site-packages/httpcore/_sync/connection_pool.py\", line 407, in __iter__ raise exc from None File \"/home/spikkie/git/ai-aip/py_env/lib/python3.12/site-packages/httpcore/_sync/connection_pool.py\", line 403, in __iter__ for part in self._stream: File \"/home/spikkie/git/ai-aip/py_env/lib/python3.12/site-packages/httpcore/_sync/http11.py\", line 342, in __iter__ raise exc File \"/home/spikkie/git/ai-aip/py_env/lib/python3.12/site-packages/httpcore/_sync/http11.py\", line 334, in __iter__ for chunk in self._connection._receive_response_body(**kwargs): File \"/home/spikkie/git/ai-aip/py_env/lib/python3.12/site-packages/httpcore/_sync/http11.py\", line 203, in _receive_response_body event = self._receive_event(timeout=timeout) ^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^ File \"/home/spikkie/git/ai-aip/py_env/lib/python3.12/site-packages/httpcore/_sync/http11.py\", line 217, in _receive_event data = self._network_stream.read( ^^^^^^^^^^^^^^^^^^^^^^^^^^ File \"/home/spikkie/git/ai-aip/py_env/lib/python3.12/site-packages/httpcore/_backends/sync.py\", line 128, in read return self._sock.recv(max_bytes) ^^^^^^^^^^^^^^^^^^^^^^^^^^ KeyboardInterrupt",
