}") PY } # Capture service logs as a best-effort diagnostic only. if [[ ${skip_docker_logs} -eq 0 ]]; then capture_docker_logs_best_effort fi prune_summary_active=0 if [[ ${prune_release_logs} -eq 1 ]]; then prune_release_logs_best_effort prune_summary_active=1 fi ''' if marker not in s: raise SystemExit('marker not found') s=s.replace(marker, insert) # Remove duplicate capture block if inserted? marker included capture so okay. # Update summary variables section: currently defines active flags after capture. Need remove duplicate prune_summary_active set? It is inserted before summary. Add summary output s=s.replace('''release_logs: ${release_log_dir} full_log: $(summary_value "${tests_summary_active}" "${full_log}") ''','''release_logs: ${release_log_dir} log_prune: $(summary_value "${prune_summary_active}" "keep=${release_log_keep}") full_log: $(summary_value "${tests_summary_active}" "${full_log}") ''') # Update versions in script? no version literal except examples maybe usage? no. p.write_text(s) PY bash -n chatgpt_claudecode_workflow_release_control.sh && grep -n "prune-release\|release-log-keep\|Release log pruning\|log_prune" chatgpt_claudecode_workflow_release_control.sh | sed -n '1,220p'

