#!/usr/bin/env bash set -euo pipefail # Export a safe, sourceable environment file for the AWX Kubernetes Bearer Token credential. # The generated values are intended for AWX jobs running inside the Kubernetes cluster. # Therefore the default API server is the in-cluster service, not the local MicroK8s host URL. NAMESPACE="${NAMESPACE:-awx}" SERVICE_ACCOUNT="${SERVICE_ACCOUNT:-awx-k8s-operator}" K8S_API_SERVER="${K8S_API_SERVER:-https://kubernetes.default.svc}" K8S_VERIFY_SSL="${K8S_VERIFY_SSL:-true}" TOKEN_DURATION="${TOKEN_DURATION:-8760h}" if [[ -n "${KUBECTL:-}" ]]; then KUBECTL_CMD=("$KUBECTL") elif command -v microk8s >/dev/null 2>&1; then KUBECTL_CMD=(microk8s kubectl) else KUBECTL_CMD=(kubectl) fi "${KUBECTL_CMD[@]}" -n "$NAMESPACE" create serviceaccount "$SERVICE_ACCOUNT" \ --dry-run=client -o yaml | "${KUBECTL_CMD[@]}" apply -f - >/dev/null # Keep the existing broad binding for the current lab stage. Tighten this later once # the final namespaces/resources are stable. "${KUBECTL_CMD[@]}" create clusterrolebinding "${SERVICE_ACCOUNT}-cluster-admin" \ --clusterrole=cluster-admin \ --serviceaccount="${NAMESPACE}:${SERVICE_ACCOUNT}" \ --dry-run=client -o yaml | "${KUBECTL_CMD[@]}" apply -f - >/dev/null K8S_BEARER_TOKEN="$("${KUBECTL_CMD[@]}" -n "$NAMESPACE" create token "$SERVICE_ACCOUNT" --duration="$TOKEN_DURATION")" K8S_CA_CERT="$("${KUBECTL_CMD[@]}" -n "$NAMESPACE" get configmap kube-root-ca.crt -o jsonpath='{.data.ca\.crt}')" if [[ "$K8S_VERIFY_SSL" == "true" ]]; then if [[ "$K8S_CA_CERT" != *"BEGIN CERTIFICATE"* || "$K8S_CA_CERT" != *"END CERTIFICATE"* ]]; then echo "ERROR: kube-root-ca.crt did not contain PEM certificate text." >&2 exit 1 fi fi K8S_CA_CERT_B64="$(printf '%s' "$K8S_CA_CERT" | base64 | tr -d '\n')" python3 - "$K8S_API_SERVER" "$K8S_BEARER_TOKEN" "$K8S_CA_CERT_B64" "$K8S_VERIFY_SSL" <<'PY' import shlex import sys keys = [ "K8S_API_SERVER", "K8S_BEARER_TOKEN", "K8S_CA_CERT_B64", "K8S_VERIFY_SSL", ] for key, value in zip(keys, sys.argv[1:]): print(f"export {key}={shlex.quote(value)}")

