CHATGPT_PROJECT_URL=https://chatgpt.com/
CHATGPT_PROFILE_DIR=./profile
CHATGPT_HEADLESS=false
CHATGPT_DEBUG=true
CHATGPT_MAX_RETRIES=1
CHATGPT_RETRY_BACKOFF_SECONDS=2.0
# CHATGPT_EMAIL=
# CHATGPT_PASSWORD=
# CHATGPT_PASSWORD_FILE=/run/secrets/chatgpt_password
# CHATGPT_BROWSER_CHANNEL=chrome
# Uncomment these to let `promptbranch ask "..."` use the Docker service without repeating flags.
# CHATGPT_SERVICE_BASE_URL=http://localhost:8000
# CHATGPT_SERVICE_TOKEN=change-me
CHATGPT_SERVICE_TIMEOUT_SECONDS=300.0

# Compose secret source on the host
CHATGPT_PASSWORD_SECRET_FILE=${HOME}/.config/chatgpt/password.txt

CHATGPT_CLEAR_PROFILE_SINGLETON_LOCKS=1

# Enable auto-reload when using `docker compose up --watch` or ./run_chatgpt_service_dev.sh
CHATGPT_UVICORN_RELOAD=0
