# .not_to_zip
# Syntax is the same as .gitignore.

# Always skip git metadata
.git/

# Python caches
*.pyo
__pycache__/
*.pyc
.pytest_cache/

# Node / frontend build outputs
node_modules/
dist/
coverage/

# Local environment / secrets
.env
.env.*
!.env.example

# Archives and generated artifacts
*.zip
*.tar.gz

# Logs
*.log
session_*.log
*.log.*
*.json.log
*.log*

# Kubernetes render output
helm-chart/charts/

# Keep one file even if a broader rule matched it
!important.log

#venv files
venv/

# profile
.pb_profile/
profile/

# debug files
debug_artifacts/

# Extracted release folders should never be repackaged
chatgpt_claudecode_workflow_v*/

# Local debug popup probes and chat/task transcript exports
debug_projects_popup_*/
task_*.messages
task_*.messages.txt
task_*_message.txt
task_*_final.txt
stdout.json
stderr.txt
task_show_*_messages.txt

# Promptbranch service start PID files
.promptbranch-service-start.*.pid
# Promptbranch release-control/test audit artifacts
pb_*.json
pb_*.report.json
promptbranch-project-list.json


# Optional custom release-control log root
release_logs/

build/

.mypy_cache/

.ruff_cache/

.venv/
